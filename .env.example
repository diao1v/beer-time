# Root compose env — copy to .env and override host ports per-machine.
# These map host:container in docker-compose.yml. Container-internal ports
# never change (always 3000 for the app, 1883 for mosquitto).

# Used by the destination LAN box if 3000 is taken by something else
LED_NOTIFIER_HOST_PORT=3000

# Rarely needs changing; bump if 1883 conflicts on the host
MQTT_HOST_PORT=1883
