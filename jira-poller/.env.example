# Jira Cloud credentials
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-token-from-id.atlassian.com

# Optional filters
# JIRA_PROJECT_KEY=PROJ
JIRA_TARGET_STATUS=Test OK
# me | any | all | <accountId>
#   me  = assignee = currentUser()
#   any = assignee is not EMPTY (anyone, but assigned)
#   all = no filter
JIRA_ASSIGNEE=me
# JIRA_JQL_EXTRA=issuetype in (Story, Task)

# Where to POST trigger events
LED_NOTIFIER_URL=http://localhost:3000/trigger

POLL_INTERVAL_MS=30000
# JQL window for `updated >= ...`. Keep larger than POLL_INTERVAL_MS to absorb slow polls.
JIRA_UPDATED_WINDOW=-2m
# Pagination: page size per request, and a hard safety cap across all pages
JIRA_PAGE_SIZE=100
JIRA_MAX_TOTAL=50

# Custom field id for the "Developer" user-picker field.
# Discover it once with:  bun run poller.ts --list-fields
# Example: customfield_10001
# JIRA_DEVELOPER_FIELD=customfield_XXXXX
