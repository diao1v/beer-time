PORT=3000
# Local broker (dev):  mqtt://localhost:1883
# HiveMQ Cloud (TLS):  mqtts://USER:PASS@your-cluster.s1.eu.hivemq.cloud:8883
# Special chars in PASS must be URL-encoded (@ -> %40, % -> %25, : -> %3A).
MQTT_URL=mqtt://localhost:1883
MQTT_TOPIC=led/command
# Optional: if set, /trigger requires X-Hub-Signature-256 header
# TRIGGER_HMAC_SECRET=change-me

# Map developer displayName -> animation name (case-insensitive).
# Pipe-separated, "Name=animation". Use "*" as the default key.
# Firmware currently supports: rainbow, fireworks, hearts, confetti
# DEVELOPER_ANIMATION_MAP=Alice Smith=fireworks|Bob Jones=hearts|*=rainbow
